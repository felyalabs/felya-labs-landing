---
import { gallerySlides } from '../data/site.js';

const toSrcset = (srcset) => srcset.map(([src, width]) => `${src} ${width}w`).join(',\n                         ');
---

<section id="gallery" class="px-8 md:px-16 pb-20 flex flex-col items-center" aria-labelledby="gallery-heading">
    <h2 id="gallery-heading" class="bg-[#111111] border border-[#222] rounded-full px-6 py-2 text-gray-300 text-sm mb-12 font-medium">
        Gallery
    </h2>

    <div class="relative w-full max-w-[1100px] mx-auto group" role="region" aria-roledescription="carousel" aria-label="Prototype concept images">

        <button id="prevBtn" type="button" aria-label="Show previous prototype image"
                class="absolute left-4 top-1/2 -translate-y-1/2 bg-[#111111]/80 hover:bg-white hover:text-black border border-[#222] text-white p-4 rounded-full z-10 transition-all duration-300 opacity-0 group-hover:opacity-100 focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-white">
            <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="m15 18-6-6 6-6"/>
            </svg>
        </button>

        <div class="surface-corners overflow-hidden bg-transparent">
            <div id="carouselTrack" class="flex transition-transform duration-500 ease-in-out">
                {gallerySlides.map((slide) => (
                    <img src={slide.src} srcset={toSrcset(slide.srcset)} sizes={slide.sizes}
                         width={slide.width} height={slide.height} alt={slide.alt} loading="lazy" decoding="async"
                         class="w-full shrink-0 aspect-video object-cover object-center">
                ))}
            </div>
        </div>

        <button id="nextBtn" type="button" aria-label="Show next prototype image"
                class="absolute right-4 top-1/2 -translate-y-1/2 bg-[#111111]/80 hover:bg-white hover:text-black border border-[#222] text-white p-4 rounded-full z-10 transition-all duration-300 opacity-0 group-hover:opacity-100 focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-white">
            <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="m9 18 6-6-6-6"/>
            </svg>
        </button>
    </div>

    <nav class="gallery-dots-bar surface-panel mx-auto mt-6 flex w-max max-w-full items-center justify-center gap-1 px-5 py-3"
         aria-label="Choose prototype image">
        {gallerySlides.map((_, index) => (
            <button
                    type="button"
                    data-carousel-dot={index}
                    data-active={index === 0 ? 'true' : 'false'}
                    aria-label={`Show prototype image ${index + 1}`}
                    aria-current={index === 0 ? 'true' : 'false'}
                    class="carousel-dot flex h-8 w-10 items-center justify-center rounded-full focus:outline-none focus-visible:ring-2 focus-visible:ring-white">
                <span class="carousel-dot__marker h-2 rounded-full" aria-hidden="true"></span>
            </button>
        ))}
    </nav>
</section>

---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/translations';
const { locale } = Astro.props as { locale: Locale };
---

<div
    class="system-demonstration"
    data-system-demonstration
    data-phase="rest"
    role="group"
    aria-label={t(locale, 'system.flowAria')}
    data-i18n-aria-label="system.flowAria"
>
    <div class="system-demonstration__stage">
        <svg
            class="system-demonstration__mobile-loop"
            viewBox="0 0 100 100"
            aria-hidden="true"
        >
            <defs>
                <mask
                    id="system-demo-mobile-collision-mask"
                    class="system-demonstration__collision-mask"
                    x="-100"
                    y="-100"
                    width="300"
                    height="300"
                    maskUnits="userSpaceOnUse"
                >
                    <rect x="-100" y="-100" width="300" height="300" fill="white" />
                    <image
                        class="system-demonstration__collision-image system-demonstration__collision-image--operator"
                        href="/assets/images/system/operator/paton-operator-short-collision.webp"
                        preserveAspectRatio="none"
                    />
                    <image
                        class="system-demonstration__collision-image system-demonstration__collision-image--robot"
                        href="/assets/images/system/openarm-system-collision.webp"
                        preserveAspectRatio="none"
                    />
                    <rect class="system-demonstration__collision-label system-demonstration__collision-label--paton" fill="black" />
                </mask>
            </defs>
            <g mask="url(#system-demo-mobile-collision-mask)">
                <path
                    class="system-demonstration__mobile-loop-path system-demonstration__mobile-loop-path--forward"
                    d="M21.716 21.716A40 40 0 0 1 78.284 78.284"
                />
                <path
                    class="system-demonstration__mobile-loop-path system-demonstration__mobile-loop-path--return"
                    d="M78.284 78.284A40 40 0 0 1 21.716 21.716"
                />
                <g class="system-demonstration__beam system-demonstration__beam--forward system-demonstration__mobile-loop-beam">
                    <path class="system-demonstration__beam-halo" d="M21.716 21.716A40 40 0 0 1 78.284 78.284" pathLength="1" />
                    <path class="system-demonstration__beam-core" d="M21.716 21.716A40 40 0 0 1 78.284 78.284" pathLength="1" />
                </g>
                <g class="system-demonstration__beam system-demonstration__beam--return system-demonstration__mobile-loop-beam">
                    <path class="system-demonstration__beam-halo" d="M78.284 78.284A40 40 0 0 1 21.716 21.716" pathLength="1" />
                    <path class="system-demonstration__beam-core" d="M78.284 78.284A40 40 0 0 1 21.716 21.716" pathLength="1" />
                </g>
            </g>
        </svg>

        <div class="system-demonstration__subject system-demonstration__subject--operator" aria-hidden="true">
            <div class="system-demonstration__operator-stack">
                <span class="system-demonstration__operator-layer system-demonstration__operator-layer--base"></span>
                <span class="system-demonstration__operator-layer system-demonstration__operator-layer--suit"></span>
                <span class="system-demonstration__operator-layer system-demonstration__operator-layer--glove-right"></span>
                <span class="system-demonstration__operator-layer system-demonstration__operator-layer--glove-left"></span>
            </div>
        </div>

        <div class="system-demonstration__subject system-demonstration__subject--robot" aria-hidden="true">
            <div class="system-demonstration__art system-demonstration__art--robot"></div>
        </div>

        <button
            class="system-demonstration__trigger system-demonstration__trigger--operator"
            type="button"
            data-system-demo-trigger="forward"
            aria-label={t(locale, 'system.stage.movement.aria')}
            data-i18n-aria-label="system.stage.movement.aria"
        ></button>
        <button
            class="system-demonstration__trigger system-demonstration__trigger--robot"
            type="button"
            data-system-demo-trigger="return"
            aria-label={t(locale, 'system.stage.action.aria')}
            data-i18n-aria-label="system.stage.action.aria"
        ></button>

        <svg
            class="system-demonstration__signals system-demonstration__signals--desktop"
            viewBox="0 0 1400 630"
            preserveAspectRatio="none"
            aria-hidden="true"
        >
            <defs>
                <marker class="system-demonstration__fallback-arrow" id="system-demo-forward-arrow" markerWidth="9" markerHeight="9" refX="8" refY="4.5" orient="auto" markerUnits="strokeWidth">
                    <path d="M0 0 9 4.5 0 9Z" />
                </marker>
                <marker class="system-demonstration__fallback-arrow" id="system-demo-return-arrow" markerWidth="9" markerHeight="9" refX="8" refY="4.5" orient="auto" markerUnits="strokeWidth">
                    <path d="M0 0 9 4.5 0 9Z" />
                </marker>
                <mask
                    id="system-demo-desktop-collision-mask"
                    class="system-demonstration__collision-mask"
                    x="0"
                    y="0"
                    width="1400"
                    height="630"
                    maskUnits="userSpaceOnUse"
                >
                    <rect width="1400" height="630" fill="white" />
                    <image
                        class="system-demonstration__collision-image system-demonstration__collision-image--operator"
                        href="/assets/images/system/operator/paton-operator-long-collision.webp"
                        preserveAspectRatio="none"
                    />
                    <image
                        class="system-demonstration__collision-image system-demonstration__collision-image--robot"
                        href="/assets/images/system/openarm-system-collision.webp"
                        preserveAspectRatio="none"
                    />
                    <rect class="system-demonstration__collision-label system-demonstration__collision-label--paton" fill="black" />
                </mask>
            </defs>

            <g mask="url(#system-demo-desktop-collision-mask)">
                <path class="system-demonstration__path system-demonstration__path--forward" d="M400 250C575 216 825 216 1000 250" marker-end="url(#system-demo-forward-arrow)" />
                <path class="system-demonstration__path system-demonstration__path--return" d="M1000 371C825 405 575 405 400 371" marker-end="url(#system-demo-return-arrow)" />
                <g class="system-demonstration__beam system-demonstration__beam--forward">
                    <path class="system-demonstration__beam-halo" d="M400 250C575 216 825 216 1000 250" pathLength="1" />
                    <path class="system-demonstration__beam-core" d="M400 250C575 216 825 216 1000 250" pathLength="1" />
                </g>
                <g class="system-demonstration__beam system-demonstration__beam--return">
                    <path class="system-demonstration__beam-halo" d="M1000 371C825 405 575 405 400 371" pathLength="1" />
                    <path class="system-demonstration__beam-core" d="M1000 371C825 405 575 405 400 371" pathLength="1" />
                </g>
            </g>
        </svg>

        <button
            class="system-demonstration__paton"
            type="button"
            data-system-demo-trigger="complete"
            aria-label={t(locale, 'system.stage.paton.aria')}
            data-i18n-aria-label="system.stage.paton.aria"
        >
            <span>PATON</span>
            <small data-i18n="system.patonLayer">{t(locale, 'system.patonLayer')}</small>
        </button>

        <p class="system-demonstration__annotation system-demonstration__annotation--forward" data-i18n="system.forward">
            {t(locale, 'system.forward')}
        </p>
        <p class="system-demonstration__annotation system-demonstration__annotation--return" data-i18n="system.return">
            {t(locale, 'system.return')}
        </p>
        <p class="system-demonstration__annotation system-demonstration__annotation--return-phone" data-i18n="system.returnShort">
            {t(locale, 'system.returnShort')}
        </p>

        <div class="system-demonstration__caption system-demonstration__caption--operator">
            <strong data-i18n="system.sequence.movement">{t(locale, 'system.sequence.movement')}</strong>
            <span data-i18n="system.sequence.capture">{t(locale, 'system.sequence.capture')}</span>
        </div>

        <div class="system-demonstration__caption system-demonstration__caption--robot">
            <strong data-i18n="system.sequence.paton">{t(locale, 'system.sequence.paton')}</strong>
            <span data-i18n="system.sequence.action">{t(locale, 'system.sequence.action')}</span>
        </div>

    </div>
</div>

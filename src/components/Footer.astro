---
import { legalLinks, socialLinks } from '../data/site.js';
import SocialIcon from './SocialIcon.astro';
---

<footer id="contact" class="px-8 md:px-16 pt-24 pb-12 bg-black border-t border-[#111]">

    <div class="mb-20 flex flex-col items-center justify-center gap-4 text-center md:flex-row md:gap-6">
        <span class="surface-panel inline-flex h-12 items-center px-6 text-sm font-medium text-gray-300 md:text-base">
            Contact Us
        </span>

        <a href="mailto:info@felyalabs.com"
           class="text-white text-base md:text-xl font-medium hover:text-gray-400 transition-colors">
            info@felyalabs.com
        </a>
    </div>
    <div class="surface-panel grid grid-cols-1 items-center gap-10 px-6 py-8 md:grid-cols-3 md:gap-12 md:px-10">
        <div class="flex flex-col items-center justify-end gap-5 md:items-start">
            <div class="flex flex-wrap justify-center gap-3 text-gray-500 md:justify-start">
                {socialLinks.map((link) => (
                    <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}
                       class="flex h-11 w-11 items-center justify-center rounded-full transition-colors hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white">
                        <SocialIcon id={link.id} />
                    </a>
                ))}
            </div>
            <p class="text-gray-400 text-sm">© FELYA LABS 2026.</p>
        </div>

        <div class="text-center flex flex-col md:items-center">
            <h2>
                <span class="block text-3xl md:text-4xl font-bold text-white mb-2 tracking-tight">Shape the future</span>
                <span class="block text-3xl md:text-4xl font-bold text-[#777777] tracking-tight">with FELYA LABS.</span>
            </h2>
        </div>

        <div class="flex flex-col items-center gap-1 text-sm font-medium text-gray-400 md:items-end">
            {legalLinks.map((link) => (
                <a href={link.href} target="_blank" class="rounded-full px-4 py-3 transition-colors hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white">{link.label}</a>
            ))}
        </div>
    </div>
</footer>
